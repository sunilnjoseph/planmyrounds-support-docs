{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "PlanMyRounds Docs",
  "colors": {
    "primary": "#5B8DF5",
    "light": "#DBADFF",
    "dark": "#2E65D4"
  },
  "favicon": {
    "light": "/images/favicon.svg",
    "dark": "/images/favicon.svg"
  },
  "navigation": {
    "pages": [
      "index",
      "quickstart",
      {
        "group": "Rosters",
        "icon": "calendar-check",
        "pages": [
          "rosters/overview",
          "rosters/creating-a-roster",
          "rosters/publishing-a-roster",
          "rosters/editing-a-published-roster",
          "rosters/roster-constraints",
          "rosters/statuses"
        ]
      },
      {
        "group": "Shifts",
        "icon": "calendar-clock",
        "pages": [
          "shifts/overview",
          "shifts/viewing-shifts",
          "shifts/creating-shifts"
        ]
      },
      {
        "group": "Swaps",
        "icon": "arrows-rotate",
        "pages": [
          "swaps/overview",
          "swaps/requesting-a-swap",
          "swaps/approving-a-swap",
          "swaps/viewing-a-swap"
        ]
      },
      {
        "group": "Leave",
        "icon": "plane-departure",
        "pages": [
          "leave/overview",
          "leave/leave-types",
          "leave/applying-for-leave",
          "leave/approval-workflow",
          "leave/cancelling-leave",
          "leave/calendar"
        ]
      },
      "scheduling-engine"
    ]
  },
  "logo": {
    "light": "/images/pmr_logo.svg",
    "dark": "/images/pmr_logo.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@planmyrounds.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open app",
      "href": "https://planmyrounds.com/"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "website": "https://planmyrounds.com/"
    }
  },
  "description": "PlanMyRounds is physician scheduling software for hospitalist groups — automate fair shift rosters, manage leaves, swaps, and on-call rotations without spreadsheets.",
  "background": {
    "color": {
      "light": "#FFFFFF",
      "dark": "#0D0F1C"
    }
  },
  "integrations": {
    "ga4": {
      "measurementId": "G-NQKWPESGYM"
    }
  },
  "redirects": [
    {
      "source": "/shifts/assigning-staff",
      "destination": "/rosters/creating-a-roster",
      "permanent": true
    },
    {
      "source": "/shifts/swaps-and-cover",
      "destination": "/swaps/overview",
      "permanent": true
    },
    {
      "source": "/shifts/publishing-and-notifications",
      "destination": "/rosters/publishing-a-roster",
      "permanent": true
    },
    {
      "source": "/shifts/shift-templates",
      "destination": "/shifts/viewing-shifts",
      "permanent": true
    }
  ],
  "appearance": {
    "default": "light"
  }
}
