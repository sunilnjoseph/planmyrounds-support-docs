{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "PlanMyRounds Docs",
  "colors": {
    "primary": "#5B8DF5",
    "light": "#DBADFF",
    "dark": "#2E65D4"
  },
  "favicon": {
    "light": "/images/favicon.svg",
    "dark": "/images/favicon.svg"
  },
  "navigation": {
    "pages": [
      "index",
      "quickstart",
      {
        "group": "Shifts",
        "icon": "calendar-clock",
        "pages": [
          "shifts/overview",
          "shifts/creating-shifts",
          "shifts/assigning-staff",
          "shifts/shift-templates",
          "shifts/swaps-and-cover",
          "shifts/publishing-and-notifications"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Blog",
          "href": "https://mintlify.com/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/images/pmr.svg",
    "dark": "/images/pmr.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@planmyrounds.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "website": "https://planmyrounds.com/"
    }
  },
  "description": "PlanMyRounds is physician scheduling software for hospitalist groups — automate fair shift rosters, manage leaves, swaps, and on-call rotations without spreadsheets.",
  "background": {
    "color": {
      "light": "#F7F6FF",
      "dark": "#0D0F1C"
    }
  }
}
